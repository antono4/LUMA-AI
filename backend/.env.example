# LUMA-AI Backend Configuration

# Required: LLM API Key (get from OpenAI, Groq, or other providers)
OPENAI_API_KEY=your-api-key-here

# Optional: LLM Model (default: gpt-4o)
# LLM_MODEL=gpt-4o

# Optional: Custom LLM Base URL (leave empty for OpenAI)
# For Groq: https://api.groq.com/openai/v1
# LLM_BASE_URL=

# Optional: Groq Model (if using Groq)
# LLM_MODEL=llama-3.1-8b-instant